# —— App ——
PUBLIC_APP_URL=http://localhost:4321
SESSION_SECRET=genera-un-secreto-largo-aleatorio
# En producción: ALLOW_ADMIN_REGISTRATION=false (por defecto desactivado en prod)
ALLOW_ADMIN_REGISTRATION=false

# Bizum (también editable en /admin/ajustes)
BIZUM_COMPANY_PHONE=+34600123456

# —— Supabase (opcional en DEMO; obligatorio en PRO) ——
# Dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# —— Email al confirmar pedido (preconfigurado) ——
# console = imprime en terminal del servidor (desarrollo)
# resend  = https://resend.com (recomendado en PRO)
EMAIL_ENABLED=true
EMAIL_PROVIDER=console
EMAIL_FROM="BocadO <pedidos@tudominio.com>"
EMAIL_REPLY_TO=soporte@tudominio.com
# Solo si EMAIL_PROVIDER=resend
EMAIL_API_KEY=

# SMTP (futuro; dejar vacío si usas resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
