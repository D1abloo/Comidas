---
import Base from '../layouts/Base.astro';
import OrdersTracker from '../components/islands/OrdersTracker.tsx';
import { listOrders } from '../server/order-service';

const user = Astro.locals.user;
const allOrders = user ? await listOrders() : [];
const initialOrders = user
  ? allOrders
      .filter((o) => o.customer.user_id === user.id || o.customer.email === user.email)
      .sort((a, b) => b.created_at.localeCompare(a.created_at))
  : [];
---
<Base title="Mis pedidos · BocadO" description="Consulta el estado de tus pedidos en BocadO.">
  <section class="container-bocado py-12 md:py-16">
    <div class="max-w-4xl animate-fade-up">
      <p class="premium-eyebrow">Seguimiento</p>
      <h1 class="premium-title mt-2">Tus pedidos</h1>
      <p class="premium-sub mt-3">
        {user
          ? 'Aquí ves el estado en tiempo real de tus pedidos con esta cuenta.'
          : 'Aquí aparecen los pedidos realizados desde este navegador.'}
      </p>
    </div>

    <div class="mt-10 max-w-5xl">
      <OrdersTracker client:load userEmail={user?.email ?? null} initialOrders={initialOrders} />
    </div>
  </section>
</Base>
