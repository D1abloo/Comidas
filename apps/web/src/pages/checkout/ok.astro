---
import Base from '../../layouts/Base.astro';
import OrderTrackInit from '../../components/islands/OrderTrackInit.tsx';
import { getStore } from '../../server/db';

const orderId = Astro.url.searchParams.get('order');
const store = getStore();
const order = orderId ? store.orders.find((o) => o.id === orderId) : null;
const invoice = order?.invoice_id ? store.invoices.find((i) => i.id === order.invoice_id) : null;
---
<Base title="Pedido confirmado · BocadO">
  {orderId && <OrderTrackInit client:load orderId={orderId} />}
  <section class="container-bocado mt-20 mb-32 max-w-xl animate-fade-up">
    <div class="w-14 h-14 rounded-full bg-bocado-lime grid place-items-center">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="2"><path d="m5 12 4 4L19 6"/></svg>
    </div>
    <h1 class="mt-6 text-4xl font-semibold tracking-[-0.02em]">¡Pedido confirmado!</h1>
    {order ? (
      <>
        <p class="mt-3 text-bocado-mute leading-relaxed">
          Tu pedido <b>{order.number}</b> está en marcha. Puedes seguir el estado en la barra inferior o en
          <a href="/pedidos" class="underline">Mis pedidos</a>.
        </p>
        {invoice && (
          <p class="mt-4 text-sm bg-bocado-paper2 rounded-xl px-4 py-3 border border-bocado-line">
            Factura <b>{invoice.number}</b> generada automáticamente.
            <a href={`/api/invoices/${invoice.id}.pdf`} target="_blank" class="underline ml-1">Descargar PDF</a>
          </p>
        )}
      </>
    ) : (
      <p class="mt-3 text-bocado-mute">Tu pedido ha sido recibido.</p>
    )}
        <div class="mt-8 flex gap-3 flex-wrap">
      <a href="/pedidos" class="btn-lime">Seguir pedido</a>
      <a href="/" class="btn-ghost">Volver al inicio</a>
    </div>
  </section>
</Base>
