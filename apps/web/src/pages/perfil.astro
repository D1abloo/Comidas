---
import Base from '../layouts/Base.astro';
import ProfileOrders from '../components/islands/ProfileOrders.tsx';
import { getStore } from '../server/db';

const user = Astro.locals.user!;
const store = getStore();
const myOrders = store.orders
  .filter((o) => o.customer.user_id === user.id || o.customer.email === user.email)
  .sort((a, b) => b.created_at.localeCompare(a.created_at));
---
<Base title="Mi cuenta · BocadO">
  <section class="container-bocado py-12 grid lg:grid-cols-[280px_1fr] gap-10">
    <aside class="card p-6 h-fit animate-fade-up">
      <p class="label">Cuenta</p>
      <h1 class="text-xl font-semibold tracking-tight mt-1">{user.full_name}</h1>
      <p class="text-sm text-bocado-mute">{user.email}</p>
      {user.phone && <p class="text-sm text-bocado-mute mt-1">{user.phone}</p>}
      <hr class="my-4 hairline" />
      <ul class="space-y-2 text-sm">
        <li><a href="/perfil" class="font-medium">Mis pedidos</a></li>
        <li><a href="/pedidos" class="text-bocado-mute hover:text-bocado-ink">Seguimiento público</a></li>
        <li><a href="/" class="text-bocado-mute hover:text-bocado-ink">Volver a la tienda</a></li>
      </ul>
      <form action="/api/auth/logout" method="POST" class="mt-6">
        <button class="btn-ghost w-full">Cerrar sesión</button>
      </form>
    </aside>

        <div>
      <h2 class="text-2xl font-semibold tracking-tight animate-fade-up">Mis pedidos</h2>
      <p class="text-sm text-bocado-mute mt-1 animate-fade-up stagger-1">
        Histórico con seguimiento detallado · {myOrders.length} pedido{myOrders.length === 1 ? '' : 's'}
      </p>
      <div class="mt-6">
        <ProfileOrders client:load orders={myOrders} />
      </div>
    </div>
  </section>
</Base>
