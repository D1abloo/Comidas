---
import Base from '../layouts/Base.astro';
import DishCard from '../components/DishCard.astro';
import { getStore } from '../server/db';

const store = getStore();
const restById = Object.fromEntries(store.restaurants.map((r) => [r.id, r]));
---
<Base title="Restaurantes · BocadO">
  <section class="container-bocado mt-12">
    <p class="label">Restaurantes seleccionados</p>
    <h1 class="text-3xl md:text-5xl font-semibold tracking-[-0.02em] mt-3">Una cocina, una historia.</h1>

    <div class="mt-12 space-y-16">
      {store.restaurants.map((r) => {
        const dishes = store.dishes.filter((d) => d.restaurant_id === r.id && d.is_available);
        return (
          <div>
            <div class="flex items-end justify-between">
              <div>
                <div class="text-[11px] uppercase tracking-wider text-bocado-mute">{r.cuisine} · ★ {r.rating}</div>
                <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mt-1">{r.name}</h2>
              </div>
              <span class="text-sm text-bocado-mute">{dishes.length} platos</span>
            </div>
            <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {dishes.slice(0, 4).map((d) => <DishCard dish={d} restaurant={restById[d.restaurant_id]!} />)}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Base>
