---
import Base from '../layouts/Base.astro';
import GlobalSearch from '../components/islands/GlobalSearch.tsx';
import { getStore } from '../server/db';

const store = getStore();
const q = Astro.url.searchParams.get('q') ?? '';
const cuisine = Astro.url.searchParams.get('cuisine') ?? '';
const diet = Astro.url.searchParams.get('diet') ?? '';
const sectionId = Astro.url.searchParams.get('seccion') ?? '';

const catalogSections = store.menu_sections
  .filter((s) => s.is_active && s.id !== 'sec-menu-dia')
  .sort((a, b) => a.sort_order - b.sort_order);

const dishes = store.dishes.filter((d) => d.menu_section_id !== 'sec-menu-dia');
const restaurants = store.restaurants.map((r) => ({ id: r.id, name: r.name }));
---
<Base title={q ? `Buscar: ${q} — BocadO` : 'Buscar platos — BocadO'} description="Busca platos en toda la carta con filtros avanzados.">
  <section class="container-bocado py-10 md:py-14 pb-28">
    <nav class="text-sm text-bocado-mute mb-6">
      <a href="/" class="hover:text-bocado-ink">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-bocado-ink font-medium">Buscar</span>
    </nav>

    <header class="mb-10">
      <p class="premium-eyebrow">Buscador</p>
      <h1 class="premium-title mt-2">Encuentra tu plato</h1>
      <p class="premium-sub mt-3">Busca por nombre, ingrediente, cocina o restaurante en toda la carta.</p>
    </header>

    <GlobalSearch
      client:load
      dishes={dishes}
      sections={catalogSections.map((s) => ({ id: s.id, title: s.title, slug: s.slug }))}
      restaurants={restaurants}
      initialQ={q}
      initialCuisine={cuisine}
      initialDiet={diet}
      initialSection={sectionId}
    />
  </section>
</Base>
