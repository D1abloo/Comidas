---
import Base from '../../layouts/Base.astro';
import { loginUser, setSession } from '../../server/auth';

let error = '';
const next = Astro.url.searchParams.get('next') ?? '/admin';

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const user = await loginUser(String(fd.get('email')), String(fd.get('password')));
    if (user.role !== 'admin') throw new Error('Esta cuenta no es de administrador.');
    await setSession(Astro.cookies, { id: user.id, email: user.email, full_name: user.full_name, role: user.role });
    return Astro.redirect(next);
  } catch (e: any) {
    error = e.message ?? 'Error';
  }
}
---
<Base title="Admin · Acceder" hideChrome>
  <section class="min-h-[calc(100vh-28px)] grid place-items-center px-6 bg-bocado-paper2">
    <div class="card w-full max-w-md p-10">
      <div class="text-[11px] uppercase tracking-wider text-bocado-mute">BocadO · Admin</div>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">Acceso del equipo</h1>
      <form method="POST" class="mt-6 space-y-3">
        <label class="block"><span class="label">Email</span>
          <input class="input mt-1" name="email" type="email" required defaultValue="admin@bocado.app" />
        </label>
        <label class="block"><span class="label">Contraseña</span>
          <input class="input mt-1" name="password" type="password" required defaultValue="admin1234" />
        </label>
        {error && <p class="text-sm text-red-600">{error}</p>}
        <button class="btn-primary w-full mt-2">Entrar al panel</button>
      </form>
      <p class="mt-6 text-xs text-bocado-mute text-center">
        ¿Sin cuenta admin? <a href="/admin/registro" class="underline">Crear cuenta de equipo</a>
      </p>
    </div>
  </section>
</Base>
