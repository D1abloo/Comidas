---
import Base from '../../layouts/Base.astro';
import { loginUser, setSession } from '../../server/auth';
import { safeRedirectPath } from '../../server/security';

let error = '';
const next = safeRedirectPath(Astro.url.searchParams.get('next'), '/admin');

if (Astro.request.method === 'POST') {
  try {
    const fd = await Astro.request.formData();
    const user = await loginUser(String(fd.get('email')), String(fd.get('password')));
    if (user.role !== 'admin') throw new Error('Esta cuenta no es de administrador.');
    await setSession(Astro.cookies, { id: user.id, email: user.email, full_name: user.full_name, role: user.role }, Astro.request);
    return Astro.redirect(next);
  } catch (e: any) {
    error = e.message ?? 'Error';
  }
}
---
<Base title="Admin · Acceder" hideChrome manifestHref="/admin-manifest.webmanifest">
  <section class="admin-login-wrap bg-bocado-paper2">
    <div class="admin-login-card">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-11 h-11 rounded-xl bg-bocado-house text-white font-bold text-lg grid place-items-center">B</span>
        <div>
          <p class="admin-login-kicker">BocadO · Admin</p>
          <h1 class="admin-login-title">Acceso del equipo</h1>
        </div>
      </div>
      <form method="POST" class="space-y-4">
        <label class="block">
          <span class="label">Email</span>
          <input class="input mt-1.5" name="email" type="email" required autocomplete="username" />
        </label>
        <label class="block">
          <span class="label">Contraseña</span>
          <input class="input mt-1.5" name="password" type="password" required autocomplete="current-password" />
        </label>
        {error && <p class="text-sm text-red-600 bg-red-50 border border-red-100 rounded-xl px-3 py-2">{error}</p>}
        <button class="btn-primary w-full mt-2">Entrar al panel</button>
      </form>
      <p class="mt-6 text-xs text-bocado-mute text-center">
        ¿Sin cuenta admin? <a href="/admin/registro" class="underline font-medium text-bocado-ink">Crear cuenta de equipo</a>
      </p>
    </div>
  </section>
</Base>
