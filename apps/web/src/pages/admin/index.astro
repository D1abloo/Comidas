---
import Admin from '../../layouts/Admin.astro';
import { getStore } from '../../server/db';
import { formatEUR, statusLabel, paymentLabel } from '../../server/format';

const store = getStore();
const today = new Date(); today.setHours(0, 0, 0, 0);
const monthStart = new Date(today.getFullYear(), today.getMonth(), 1);

const salesToday = store.orders
  .filter((o) => new Date(o.created_at) >= today && o.payment_status === 'paid')
  .reduce((s, o) => s + o.total_cents, 0);
const activeOrders = store.orders.filter((o) => ['pending', 'confirmed', 'preparing', 'delivering'].includes(o.status)).length;
const monthly = store.orders
  .filter((o) => new Date(o.created_at) >= monthStart && o.payment_status === 'paid')
  .reduce((s, o) => s + o.total_cents, 0);
const outOfStock = store.dishes.filter((d) => !d.is_available).length;

// Serie últimos 7 días
const series: { d: string; total: number }[] = [];
for (let i = 6; i >= 0; i--) {
  const dt = new Date();
  dt.setHours(0, 0, 0, 0);
  dt.setDate(dt.getDate() - i);
  const next = new Date(dt); next.setDate(dt.getDate() + 1);
  const total = store.orders
    .filter((o) => new Date(o.created_at) >= dt && new Date(o.created_at) < next)
    .reduce((s, o) => s + o.total_cents, 0);
  series.push({ d: ['D', 'L', 'M', 'X', 'J', 'V', 'S'][dt.getDay()]!, total });
}
const maxVal = Math.max(...series.map((s) => s.total), 1);
const w = 680, h = 200, padX = 10;
const pts = series.map((s, i) => ({
  x: padX + (i * (w - padX * 2)) / (series.length - 1),
  y: h - (s.total / maxVal) * (h - 30) - 10,
  d: s.d,
  total: s.total,
}));
const linePath = pts.map((p, i) => (i === 0 ? `M ${p.x},${p.y}` : `L ${p.x},${p.y}`)).join(' ');
const areaPath = `${linePath} L ${pts[pts.length - 1]!.x},210 L ${pts[0]!.x},210 Z`;

const recent = store.orders.slice(0, 5);
---
<Admin title="Dashboard" crumb="Inicio / Dashboard">
  <section class="space-y-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="card p-5">
        <div class="label">Ventas hoy</div>
        <div class="mt-2 text-2xl font-semibold">{formatEUR(salesToday)}</div>
        <div class="text-xs text-bocado-mute mt-1">solo pagadas</div>
      </div>
      <div class="card p-5">
        <div class="label">Pedidos activos</div>
        <div class="mt-2 text-2xl font-semibold">{activeOrders}</div>
        <div class="text-xs text-bocado-mute mt-1">en curso</div>
      </div>
      <div class="card p-5">
        <div class="label">Facturación mensual</div>
        <div class="mt-2 text-2xl font-semibold">{formatEUR(monthly)}</div>
        <div class="text-xs text-bocado-mute mt-1">acumulado</div>
      </div>
      <div class="card p-5">
        <div class="label">Platos agotados</div>
        <div class="mt-2 text-2xl font-semibold">{outOfStock}</div>
        <div class="text-xs text-bocado-mute mt-1">requieren reposición</div>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1.4fr_1fr] gap-6">
      <div class="card p-6">
        <div class="flex items-center justify-between">
          <h3 class="font-semibold tracking-tight">Ventas últimos 7 días</h3>
          <span class="chip">EUR</span>
        </div>
        <svg viewBox="0 0 700 220" class="w-full h-[240px] mt-6">
          <defs>
            <linearGradient id="g" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#D6FF3D" stop-opacity="0.5" />
              <stop offset="100%" stop-color="#D6FF3D" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path d={areaPath} fill="url(#g)" />
          <path d={linePath} fill="none" stroke="#0a0a0a" stroke-width="1.6" />
          {pts.map((p) => (
            <>
              <circle cx={p.x} cy={p.y} r="3" fill="#0a0a0a" />
              <text x={p.x} y="215" text-anchor="middle" font-size="10" fill="#7A7670">{p.d}</text>
            </>
          ))}
        </svg>
      </div>

      <div class="card p-6">
        <h3 class="font-semibold tracking-tight">Últimos pedidos</h3>
        <table class="w-full mt-4 text-sm">
          <thead class="text-bocado-mute">
            <tr class="text-left">
              <th class="font-normal py-2">Pedido</th>
              <th class="font-normal">Cliente</th>
              <th class="font-normal">Total</th>
              <th class="font-normal">Estado</th>
            </tr>
          </thead>
          <tbody>
            {recent.map((o) => (
              <tr class="border-t border-bocado-line">
                <td class="py-3">{o.number}</td>
                <td>{o.customer.full_name}</td>
                <td>{formatEUR(o.total_cents)}</td>
                <td><span class="chip">{statusLabel(o.status)}</span></td>
              </tr>
            ))}
            {recent.length === 0 && <tr><td colspan="4" class="py-6 text-center text-bocado-mute">Sin pedidos.</td></tr>}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Admin>
