---
import Admin from '../../layouts/Admin.astro';
import BizumQRPanel from '../../components/islands/BizumQRPanel.tsx';
import { getStore } from '../../server/db';
import { formatEUR, statusLabel } from '../../server/format';

const store = getStore();
const orders = store.orders;
const byMethod: Record<string, number> = { tpv: 0, bizum: 0, cash: 0 };
orders.forEach((o) => (byMethod[o.payment_method] = (byMethod[o.payment_method] ?? 0) + 1));
const total = orders.length || 1;
---
<Admin title="Pagos" crumb="Inicio / Pagos">
  <section class="admin-content space-y-5 !py-0">
    <BizumQRPanel
      client:load
      phone={store.settings.bizum_phone}
      conceptTemplate={store.settings.bizum_concept_template}
      updatedAt={store.settings.bizum_qr_updated_at}
    />

    <div class="grid md:grid-cols-3 gap-3">
      {(['tpv', 'bizum', 'cash'] as const).map((m) => (
        <div class="card p-4">
                    <div class="label">{m === 'tpv' ? 'Tarjeta · TPV' : m === 'bizum' ? 'Bizum' : 'Efectivo'}</div>
          <div class="mt-2 text-2xl font-semibold">{Math.round(((byMethod[m] ?? 0) / total) * 100)}%</div>
          <div class="text-xs text-bocado-mute mt-1">{byMethod[m] ?? 0} pedidos</div>
        </div>
      ))}
    </div>

    <div class="admin-frame overflow-x-auto">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Pedido</th>
            <th>Método</th>
            <th>Importe</th>
            <th>Estado pago</th>
          </tr>
        </thead>
        <tbody>
          {orders.map((o) => (
            <tr>
              <td class="font-medium">{o.number}</td>
              <td><span class="chip text-[10px] uppercase">{o.payment_method}</span></td>
              <td>{formatEUR(o.total_cents)}</td>
              <td><span class="chip text-[10px]">{statusLabel(o.payment_status)}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Admin>
