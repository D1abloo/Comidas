---
import Base from '../../layouts/Base.astro';
import SectionMenu from '../../components/islands/SectionMenu.tsx';
import { getStore } from '../../server/db';

const { slug } = Astro.params;
const store = getStore();
const section = store.menu_sections.find((s) => s.slug === slug && s.is_active);

if (!section) {
  return Astro.redirect('/');
}

const q = Astro.url.searchParams.get('q') ?? '';
const cuisine = Astro.url.searchParams.get('cuisine') ?? '';
const diet = Astro.url.searchParams.get('diet') ?? '';
const restaurant = Astro.url.searchParams.get('restaurante') ?? '';

const sectionDishes = store.dishes.filter((d) => d.menu_section_id === section.id);
const restNames = store.restaurants.map((r) => ({ id: r.id, name: r.name }));
---
<Base title={`${section.title} — BocadO`} description={section.description ?? `Todos los platos de ${section.title}`}>
  <section class="container-bocado py-10 md:py-14 pb-28">
    <nav class="text-sm text-bocado-mute mb-6 animate-fade-up">
      <a href="/" class="hover:text-bocado-ink">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/#catalogo" class="hover:text-bocado-ink">Carta</a>
      <span class="mx-2">/</span>
      <span class="text-bocado-ink font-medium">{section.title}</span>
    </nav>

    <header class="mb-10 animate-fade-up">
      <p class="premium-eyebrow">Carta completa</p>
      <div class="flex items-center gap-4 mt-2">
        <span class="text-4xl">{section.emoji}</span>
        <div>
          <h1 class="premium-title">{section.title}</h1>
          {section.description && <p class="premium-sub mt-2">{section.description}</p>}
        </div>
      </div>
    </header>

    <SectionMenu
      client:load
      section={{ id: section.id, title: section.title, slug: section.slug, emoji: section.emoji, description: section.description }}
      dishes={sectionDishes}
      restaurants={restNames}
      initialQ={q}
      initialCuisine={cuisine}
      initialDiet={diet}
      initialRestaurant={restaurant}
    />
  </section>
</Base>
