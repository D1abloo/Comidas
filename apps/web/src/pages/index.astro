---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Filters from '../components/Filters.astro';
import BestsellerCarousel from '../components/islands/BestsellerCarousel.tsx';
import MenuCatalog from '../components/islands/MenuCatalog.tsx';
import TrustBar from '../components/TrustBar.astro';
import { getStore } from '../server/db';
import type { Dish } from '../server/types';

const store = getStore();
const cuisine = Astro.url.searchParams.get('cuisine') ?? '';
const diet = Astro.url.searchParams.get('diet') ?? '';
const maxTime = parseInt(Astro.url.searchParams.get('max_time') ?? '0', 10);

let dishes = store.dishes.filter((d) => d.is_available);
if (cuisine) dishes = dishes.filter((d) => d.cuisine === cuisine);
if (diet === 'vegan') dishes = dishes.filter((d) => d.vegan);
if (diet === 'vegetarian') dishes = dishes.filter((d) => d.vegetarian);
if (diet === 'gluten_free') dishes = dishes.filter((d) => d.gluten_free);
if (maxTime > 0) dishes = dishes.filter((d) => d.delivery_time_min <= maxTime);

const sections = store.menu_sections.filter((s) => s.is_active).sort((a, b) => a.sort_order - b.sort_order);
const restNames = Object.fromEntries(store.restaurants.map((r) => [r.id, r.name]));

const soldCount = new Map<string, number>();
for (const o of store.orders) {
  for (const line of o.items) {
    soldCount.set(line.dish_id, (soldCount.get(line.dish_id) ?? 0) + line.quantity);
  }
}

let bestsellers: (Dish & { sold_count?: number })[] = [...dishes]
  .map((d) => ({ ...d, sold_count: soldCount.get(d.id) ?? 0 }))
  .filter((d) => d.sold_count > 0)
  .sort((a, b) => b.sold_count - a.sold_count)
  .slice(0, 10);

if (bestsellers.length < 4) {
  bestsellers = dishes
    .filter((d) => d.is_featured)
    .slice(0, 8)
    .map((d) => ({ ...d, sold_count: soldCount.get(d.id) ?? 0 }));
}
---
<Base>
  <Hero />
  <BestsellerCarousel client:load dishes={bestsellers} restaurants={restNames} />
  <Filters />

  <section id="catalogo" class="container-bocado mt-10 pb-24">
    <MenuCatalog client:load sections={sections} dishes={dishes} restaurants={restNames} />
  </section>

  <TrustBar />
</Base>
