---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CategoryStrip from '../components/CategoryStrip.astro';
import DailyMenu from '../components/DailyMenu.astro';
import BestsellerCarousel from '../components/islands/BestsellerCarousel.tsx';
import MenuCatalog from '../components/islands/MenuCatalog.tsx';
import { getStore } from '../server/db';
import { listOrders } from '../server/order-service';
import type { Dish } from '../server/types';

const q = Astro.url.searchParams.get('q');
if (q?.trim()) {
  return Astro.redirect(`/buscar?q=${encodeURIComponent(q.trim())}`);
}

const store = getStore();
const dishes = store.dishes;
const dishesForOrder = store.dishes.filter((d) => d.is_available);
const allOrders = await listOrders();

const allSections = store.menu_sections.filter((s) => s.is_active).sort((a, b) => a.sort_order - b.sort_order);
const catalogSections = allSections.filter((s) => s.id !== 'sec-menu-dia');
const dailyDishes = dishes.filter((d) => d.menu_section_id === 'sec-menu-dia');
const restNames = Object.fromEntries(store.restaurants.map((r) => [r.id, r.name]));
const dateLabel = new Intl.DateTimeFormat('es-ES', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
}).format(new Date());

const soldCount = new Map<string, number>();
for (const o of allOrders) {
  for (const line of o.items) {
    soldCount.set(line.dish_id, (soldCount.get(line.dish_id) ?? 0) + line.quantity);
  }
}

let bestsellers: (Dish & { sold_count?: number })[] = [...dishesForOrder]
  .map((d) => ({ ...d, sold_count: soldCount.get(d.id) ?? 0 }))
  .filter((d) => d.sold_count > 0)
  .sort((a, b) => b.sold_count - a.sold_count)
  .slice(0, 10);

if (bestsellers.length < 4) {
  bestsellers = dishesForOrder
    .filter((d) => d.is_featured)
    .slice(0, 8)
    .map((d) => ({ ...d, sold_count: soldCount.get(d.id) ?? 0 }));
}
---
<Base>
  <Hero />
  <CategoryStrip />

  <section class="trust-strip animate-fade-up stagger-1" aria-label="Ventajas de BocadO">
    <div class="container-bocado grid sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-bocado-line/60">
      <div class="trust-strip-item">
        <span class="trust-strip-icon trust-strip-icon--pulse" aria-hidden="true">⚡</span>
        <div>
          <p class="text-sm font-semibold text-bocado-ink">Entrega 20–40 min</p>
          <p class="text-xs text-bocado-mute mt-0.5">Seguimiento en tiempo real</p>
        </div>
      </div>
      <div class="trust-strip-item">
        <span class="trust-strip-icon" aria-hidden="true">📸</span>
        <div>
          <p class="text-sm font-semibold text-bocado-ink">Fotos reales</p>
          <p class="text-xs text-bocado-mute mt-0.5">Lo que ves es lo que comes</p>
        </div>
      </div>
      <div class="trust-strip-item">
        <span class="trust-strip-icon" aria-hidden="true">🧾</span>
        <div>
          <p class="text-sm font-semibold text-bocado-ink">Factura al instante</p>
          <p class="text-xs text-bocado-mute mt-0.5">PDF y ticket con QR</p>
        </div>
      </div>
    </div>
  </section>

  <BestsellerCarousel client:load dishes={bestsellers} restaurants={restNames} />
  <DailyMenu dishes={dailyDishes} restaurants={store.restaurants} dateLabel={dateLabel} />

  <section id="catalogo" class="container-bocado mt-12 md:mt-16 pb-28 scroll-mt-28">
    <div class="mb-10 animate-fade-up">
      <p class="premium-eyebrow">Nuestra carta</p>
      <h2 class="premium-title mt-2">Elige tu próximo plato</h2>
      <p class="premium-sub mt-3">Pizzas, pasta, cazuelas y mucho más — cocinado en restaurantes de barrio con entrega rápida.</p>
    </div>
    <MenuCatalog client:load sections={catalogSections} dishes={dishes} restaurants={restNames} />
  </section>

</Base>
