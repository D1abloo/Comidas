---
const stats = [
  { value: '4.9', label: 'Valoración media' },
  { value: '25 min', label: 'Entrega media' },
  { value: '30+', label: 'Platos en carta' },
];
---
<section class="container-bocado pt-8 md:pt-12 pb-2">
  <div class="food-hero p-7 sm:p-10 md:p-14 lg:p-16 grid lg:grid-cols-[1.08fr_0.92fr] gap-10 lg:gap-12 items-center animate-fade-up">
    <div class="relative z-10">
      <p class="hero-kicker">
        <span class="hero-kicker-dot" aria-hidden="true"></span>
        Delivery premium · Madrid
      </p>
      <h1 class="hero-title">
        Comida de verdad,<br />
        <em class="text-bocado-lime not-italic">en tu puerta.</em>
      </h1>
      <p class="mt-5 text-white/72 text-base sm:text-lg max-w-lg leading-relaxed">
        Pizzas al horno, cazuelas caseras y bowls frescos — fotos reales, seguimiento en vivo y factura al instante.
      </p>

      <form action="/buscar" method="get" class="hero-search mt-8" role="search">
        <label for="hero-q" class="sr-only">Buscar platos</label>
        <span class="hero-search-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m16 16 5 5"></path>
          </svg>
        </span>
        <input id="hero-q" name="q" type="search" placeholder="¿Qué te apetece hoy? Pizza, ramen, postre…" autocomplete="off" />
        <button type="submit" class="hero-search-btn">Buscar</button>
      </form>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/api/carta.pdf" target="_blank" rel="noopener noreferrer" class="btn-lime text-sm sm:text-base px-6 py-3.5">Ver carta PDF</a>
        <a href="#catalogo" class="btn-hero-ghost">Explorar carta</a>
      </div>

      <ul class="mt-9 flex flex-wrap gap-2.5 text-sm">
        <li class="premium-stat">
          <span class="text-bocado-lime font-bold text-base sm:text-lg">20–40 min</span>
          <span class="text-white/50 text-[11px] uppercase tracking-wider">entrega</span>
        </li>
        <li class="premium-stat">
          <span class="text-white font-semibold text-sm">Bizum · TPV</span>
          <span class="text-white/50 text-[11px] uppercase tracking-wider">y efectivo</span>
        </li>
        <li class="premium-stat">
          <span class="text-white font-semibold text-sm">Factura</span>
          <span class="text-white/50 text-[11px] uppercase tracking-wider">automática</span>
        </li>
      </ul>
    </div>

    <div class="relative hidden lg:block z-10">
      <div class="hero-collage">
        <div class="hero-collage-main">
          <img
            src="/carta/pizza-margherita-bufala.jpg"
            alt="Pizza margherita artesanal"
            width="800"
            height="560"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <div class="hero-collage-side">
          <img src="/carta/ramen-tonkotsu.jpg" alt="Ramen tonkotsu" width="400" height="260" class="w-full h-[48%] object-cover rounded-2xl shadow-xl ring-1 ring-white/10" loading="lazy" />
          <img src="/carta/cocido-madrileno.jpg" alt="Cocido madrileño" width="400" height="260" class="w-full h-[48%] object-cover rounded-2xl shadow-xl ring-1 ring-white/10" loading="lazy" />
        </div>
      </div>
      <div class="absolute -bottom-5 left-4 right-4 flex justify-between items-end gap-3">
        <div class="hero-badge-lime">★ 4.9 · Miles de pedidos</div>
        <div class="hero-stats-float">
          {stats.map((s) => (
            <div class="text-center px-2 min-w-[4.5rem]">
              <div class="text-bocado-lime font-display text-lg leading-none">{s.value}</div>
              <div class="text-[9px] uppercase tracking-wider text-white/50 mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
