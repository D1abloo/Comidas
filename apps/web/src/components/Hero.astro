<section class="container-bocado pt-16 pb-10">
  <div class="grid md:grid-cols-[1.15fr_1fr] gap-12 items-center">
    <div>
      <p class="label">BocadO · Comida a domicilio</p>
      <h1 class="mt-4 font-semibold tracking-[-0.03em] text-[56px] leading-[1.02] md:text-[72px]">
        Sabores limpios.<br/>Entrega real.
      </h1>
      <p class="mt-5 text-bocado-mute text-lg max-w-xl">
        Comida seleccionada con fotos reales, tiempos verificados y entrega rápida.
        Información completa de cada plato: ingredientes, alérgenos y nutrición.
      </p>
      <div class="mt-8 flex gap-3 flex-wrap">
        <a href="#catalogo" class="btn-primary">Pedir ahora →</a>
        <a href="#destacados" class="btn-ghost">Ver destacados</a>
      </div>
      <ul class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm text-bocado-mute">
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-bocado-lime rounded-full"></span> Entrega 20/40 min</li>
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-bocado-lime rounded-full"></span> TPV, Bizum y efectivo</li>
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-bocado-lime rounded-full"></span> 14 alérgenos UE</li>
      </ul>
    </div>
    <div class="relative">
      <div class="aspect-[4/5] rounded-[28px] overflow-hidden bg-bocado-paper2">
        <img src="https://images.unsplash.com/photo-1604908554007-fafd5b95cb43?auto=format&fit=crop&w=900&q=80" alt="Bowl de comida saludable" class="w-full h-full object-cover" />
      </div>
      <div class="absolute -bottom-4 -left-4 bg-bocado-lime text-bocado-ink px-4 py-2 rounded-full text-sm font-medium shadow-card">
        20–30 min · Hoy
      </div>
      <div class="absolute -top-4 -right-4 bg-white border border-bocado-line px-4 py-2 rounded-full text-sm shadow-card">
        ★ 4.9 · 1.248 pedidos hoy
      </div>
    </div>
  </div>
</section>
