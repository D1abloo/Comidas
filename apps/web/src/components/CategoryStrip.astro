---
const cats = [
  { emoji: '🍕', label: 'Pizza', href: '/carta/pizza-pasta' },
  { emoji: '🍜', label: 'Asiático', href: '/buscar?cuisine=Asiática' },
  { emoji: '🍲', label: 'Cazuelas', href: '/carta/cazuelas' },
  { emoji: '🍔', label: 'Burgers', href: '/buscar?cuisine=Burgers' },
  { emoji: '🥗', label: 'Saludable', href: '/buscar?diet=vegan' },
  { emoji: '🍝', label: 'Pasta', href: '/carta/pizza-pasta' },
  { emoji: '🥤', label: 'Bebidas', href: '/carta/bebidas' },
  { emoji: '🍰', label: 'Postres', href: '/carta/postres' },
];
---
<section class="category-rail-wrap animate-fade-up stagger-2" aria-label="Categorías rápidas">
  <div class="container-bocado">
    <p class="category-rail-label">Explora por tipo</p>
    <div class="category-rail scrollbar-hide">
      {cats.map((c) => (
        <a href={c.href} class="category-pill">
          <span class="category-pill-emoji" aria-hidden="true">{c.emoji}</span>
          <span class="category-pill-text">{c.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>
