---
const cats = [
  { emoji: '🍕', label: 'Pizza', href: '/?cuisine=Italiana#catalogo' },
  { emoji: '🍜', label: 'Asiático', href: '/?cuisine=Asiática#catalogo' },
  { emoji: '🍲', label: 'Cazuelas', href: '/#catalogo' },
  { emoji: '🍔', label: 'Burgers', href: '/?cuisine=Burgers#catalogo' },
  { emoji: '🥗', label: 'Saludable', href: '/?diet=vegan#catalogo' },
  { emoji: '🍝', label: 'Pasta', href: '/?cuisine=Italiana#catalogo' },
];
---
<section class="container-bocado -mt-2 mb-2 animate-fade-up stagger-2" aria-label="Categorías rápidas">
  <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide snap-x snap-mandatory">
    {cats.map((c) => (
      <a
        href={c.href}
        class="snap-start shrink-0 flex flex-col items-center gap-2 min-w-[88px] p-4 rounded-2xl bg-white border border-bocado-line/80 shadow-sm hover:shadow-premium hover:border-bocado-lime/40 hover:-translate-y-1 transition-all duration-300"
      >
        <span class="text-2xl">{c.emoji}</span>
        <span class="text-xs font-semibold text-bocado-ink">{c.label}</span>
      </a>
    ))}
  </div>
</section>
