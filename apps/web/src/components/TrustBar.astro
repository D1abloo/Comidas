---
const items = [
  { icon: '⚡', title: 'Entrega 20–40 min', desc: 'Tiempos reales por restaurante y zona.' },
  { icon: '🔒', title: 'Pago seguro', desc: 'Bizum, tarjeta TPV o efectivo al recibir.' },
  { icon: '📋', title: 'Alérgenos UE', desc: 'Los 14 alérgenos declarados en cada plato.' },
  { icon: '🧾', title: 'Factura PDF', desc: 'Generada automáticamente al confirmar.' },
];
---
<section class="container-bocado mt-16 md:mt-24 pb-8">
  <div class="text-center mb-10 animate-fade-up">
    <p class="premium-eyebrow">Por qué BocadO</p>
    <h2 class="premium-title mt-2">Delivery que puedes confiar</h2>
  </div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
    {items.map((it, i) => (
      <div class="trust-card animate-fade-up" style={`animation-delay: ${i * 0.06}s`}>
        <span class="text-3xl mb-4 block">{it.icon}</span>
        <h4 class="font-semibold text-lg">{it.title}</h4>
        <p class="text-sm text-bocado-mute mt-2 leading-relaxed">{it.desc}</p>
      </div>
    ))}
  </div>
</section>
