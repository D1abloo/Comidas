---
const items = [
  { title: 'Entrega 20/40 min', desc: 'Tiempos verificados por restaurante.' },
  { title: 'Pago seguro', desc: 'TPV, Bizum y efectivo.' },
  { title: 'Alérgenos UE', desc: 'Los 14 alérgenos en cada plato.' },
  { title: 'Factura PDF', desc: 'Con tus datos fiscales si lo necesitas.' },
];
---
<section class="container-bocado mt-20">
  <div class="grid md:grid-cols-4 border-t border-b border-bocado-line divide-x divide-bocado-line">
    {items.map((it) => (
      <div class="py-8 px-6">
        <div class="w-8 h-8 rounded-full bg-bocado-lime grid place-items-center mb-3">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.8"><path d="m5 12 4 4L19 6"/></svg>
        </div>
        <h4 class="font-medium">{it.title}</h4>
        <p class="text-sm text-bocado-mute mt-1">{it.desc}</p>
      </div>
    ))}
  </div>
</section>
