---
import type { Dish, Restaurant } from '../server/types';
import DishCard from './DishCard.astro';

interface Props {
  dishes: Dish[];
  restaurants: Restaurant[];
  dateLabel: string;
}

const { dishes, restaurants, dateLabel } = Astro.props as Props;
const restById = Object.fromEntries(restaurants.map((r) => [r.id, r]));

if (!dishes.length) return null;
---
<section id="menu-del-dia" class="container-bocado mt-12 md:mt-16 scroll-mt-28 animate-fade-up">
  <div class="daily-menu-banner rounded-3xl border border-bocado-line/80 bg-gradient-to-br from-bocado-lime/25 via-white to-bocado-coral/10 p-6 md:p-10">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
      <div>
        <p class="premium-eyebrow">Hoy en BocadO</p>
        <h2 class="premium-title mt-2">Menú del día</h2>
        <p class="premium-sub mt-2 max-w-xl">
          Platos seleccionados por nuestros chefs para hoy · {dateLabel}
        </p>
      </div>
      <a href="/api/carta.pdf" target="_blank" rel="noopener noreferrer" class="btn-lime shrink-0 self-start md:self-auto">
        Ver carta PDF →
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {dishes.map((dish) => (
        <DishCard dish={dish} restaurant={restById[dish.restaurant_id]!} />
      ))}
    </div>
  </div>
</section>
