---
interface Props {
  size?: number;
  variant?: 'dark' | 'light';
  showWordmark?: boolean;
  className?: string;
  animated?: boolean;
}
const { size = 32, variant = 'light', showWordmark = true, className = '', animated = true } = Astro.props as Props;
const stroke = variant === 'dark' ? '#ffffff' : '#0a0a0a';
const bun = variant === 'dark' ? '#ffffff' : '#0a0a0a';
const wordmark = variant === 'dark' ? 'text-white' : 'text-bocado-ink';
const lime = '#D6FF3D';
---
<a
  href="/"
  class:list={['logo-burger inline-flex items-center gap-2.5 group', className, animated && 'animate-burger']}
  aria-label="BocadO inicio"
>
  <svg width={size} height={size} viewBox="0 0 40 40" fill="none" aria-hidden="true" class="shrink-0">
    <!-- Contenedor / plato sutil -->
    <circle cx="20" cy="20" r="18" stroke={stroke} stroke-width="1.2" opacity="0.25" />
    <!-- Pan superior -->
    <path
      class="burger-bun-top"
      d="M10 14c0-3.3 2.5-6 10-6s10 2.7 10 6"
      stroke={bun}
      stroke-width="1.8"
      stroke-linecap="round"
      fill="none"
    />
  <ellipse cx="20" cy="14" rx="9" ry="2.5" fill={bun} opacity="0.12" />
    <!-- Lechuga -->
    <path d="M11 17.5c2.5-1 4.5-1.5 9-1.5s6.5.5 9 1.5" stroke={lime} stroke-width="1.4" stroke-linecap="round" fill="none" />
    <!-- Carne / patty -->
    <rect class="burger-patty" x="11" y="19" width="18" height="4.5" rx="2.2" fill={lime} />
    <!-- Pan inferior -->
    <path d="M10 26c0 2.8 2.5 5 10 5s10-2.2 10-5" stroke={bun} stroke-width="1.8" stroke-linecap="round" fill="none" />
    <ellipse cx="20" cy="30.5" rx="8" ry="2" fill={bun} opacity="0.15" />
    <!-- Pin entrega -->
    <circle cx="30" cy="11" r="3" fill={lime} stroke={stroke} stroke-width="0.8" />
    <path d="M30 14v3" stroke={stroke} stroke-width="1" stroke-linecap="round" />
  </svg>
  {showWordmark && (
    <span class={`font-semibold tracking-[-0.03em] text-[18px] leading-none ${wordmark} group-hover:tracking-[-0.02em] transition-all duration-300`}>
      Bocad<span style={`color:${lime}`}>O</span>
    </span>
  )}
</a>
