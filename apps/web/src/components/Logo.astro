---
interface Props { size?: number; variant?: 'dark' | 'light'; showWordmark?: boolean; className?: string }
const { size = 28, variant = 'light', showWordmark = true, className = '' } = Astro.props as Props;
const stroke = variant === 'dark' ? '#fff' : '#0a0a0a';
const wordmark = variant === 'dark' ? 'text-white' : 'text-bocado-ink';
---
<a href="/" class={`inline-flex items-center gap-2 ${className}`} aria-label="BocadO inicio">
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
    <circle cx="16" cy="16" r="13" stroke={stroke} stroke-width="1.6" />
    <path d="M22 7 L27 11 L23 13 L22 7 Z" fill="#D6FF3D" stroke={stroke} stroke-width="1" stroke-linejoin="round" />
    <circle cx="16" cy="16" r="2" fill={stroke} />
  </svg>
  {showWordmark && (
    <span class={`font-semibold tracking-[-0.02em] text-[18px] leading-none ${wordmark}`}>
      Bocad<span style="color:#D6FF3D">O</span>
    </span>
  )}
</a>
