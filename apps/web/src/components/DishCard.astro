---
import type { Dish, Restaurant } from '../server/types';
import { formatEUR } from '../server/format';
import AddToCart from './islands/AddToCart.tsx';
import FavoriteHeart from './islands/FavoriteHeart.tsx';
import AllergenBadges from './AllergenBadges.astro';
import AvailabilityBadge from './AvailabilityBadge.astro';

interface Props { dish: Dish; restaurant: Restaurant }
const { dish, restaurant } = Astro.props as Props;
const img = dish.images[0]!;
const dietBadges: string[] = [];
if (dish.vegan) dietBadges.push('Vegano');
else if (dish.vegetarian) dietBadges.push('Vegetariano');
if (dish.gluten_free) dietBadges.push('Sin gluten');
---
<article class:list={['card overflow-hidden group flex flex-col', !dish.is_available && 'opacity-90']}>
  <a href={`/platos/${dish.slug}`} class="block relative aspect-[5/4] overflow-hidden">
    <img src={img} alt={dish.name} loading="lazy"
         class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
    <div class="absolute top-3 left-3">
      <AvailabilityBadge available={dish.is_available} size="md" />
    </div>
    <div class="absolute top-3 right-3"><FavoriteHeart client:idle id={dish.id} /></div>
    {dietBadges.length > 0 && (
      <div class="absolute bottom-3 left-3 flex gap-1.5">
        {dietBadges.map((b) => (
          <span class="bg-bocado-lime text-bocado-ink text-[10px] uppercase tracking-wider font-medium px-2 py-0.5 rounded-full">{b}</span>
        ))}
      </div>
    )}
  </a>
  <div class="p-5 flex-1 flex flex-col">
    <div class="text-[11px] uppercase tracking-[0.12em] text-bocado-mute">{restaurant.name}</div>
    <h3 class="mt-1 font-medium text-[17px] leading-tight">
      <a href={`/platos/${dish.slug}`}>{dish.name}</a>
    </h3>
    <div class="mt-2 flex items-center gap-3 text-xs text-bocado-mute">
      <span class="inline-flex items-center gap-1">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="#0a0a0a"><path d="m12 17.3 6.18 3.7-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        {dish.rating.toFixed(1)}
      </span>
      <span class="inline-flex items-center gap-1">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        {dish.delivery_time_min} min
      </span>
      <span>{dish.nutrition.kcal} kcal</span>
    </div>
    <div class="mt-3"><AllergenBadges allergens={dish.allergens.slice(0, 3)} /></div>
    <div class="mt-4 flex items-center justify-between">
      <span class="font-semibold">{formatEUR(dish.price_cents)}</span>
      {dish.is_available ? (
        <AddToCart client:idle line={{ dish_id: dish.id, dish_name: dish.name, restaurant_name: restaurant.name, unit_price_cents: dish.price_cents, image: img }} />
      ) : (
        <span class="text-xs text-bocado-mute">No disponible</span>
      )}
    </div>
  </div>
</article>
