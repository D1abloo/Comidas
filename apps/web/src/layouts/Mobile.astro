---
import '../styles/global.css';
import MobileRouteGuard from '../components/islands/MobileRouteGuard.tsx';
interface Props { title?: string }
const { title = 'BocadO' } = Astro.props as Props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a2421" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/mobile-manifest.webmanifest" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="mobile-shell font-admin bg-bocado-paper2 text-bocado-ink min-h-screen">
    <MobileRouteGuard client:load />
    <slot />
  </body>
</html>
