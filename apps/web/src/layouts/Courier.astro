---
import '../styles/global.css';
import DemoBanner from '../components/DemoBanner.astro';
interface Props { title?: string }
const { title = 'Repartidor' } = Astro.props as Props;
const user = Astro.locals.user!;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a2421" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="manifest" href="/repartidor-manifest.webmanifest" />
    <title>{title} · BocadO Repartidor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="courier-shell font-admin">
    <DemoBanner />
    <slot />
  </body>
</html>
