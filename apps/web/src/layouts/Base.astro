---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DemoBanner from '../components/DemoBanner.astro';
import OrderTrackerBar from '../components/islands/OrderTrackerBar.tsx';
interface Props { title?: string; description?: string; hideChrome?: boolean }
const { title = 'BocadO — Comida real, entrega rápida', description = 'Tienda online de comida a domicilio con fotos reales, tiempos verificados y entrega rápida.', hideChrome = false } = Astro.props as Props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&display=swap" rel="stylesheet" />
  </head>
  <body class="store-front bg-bocado-paper text-bocado-ink min-h-screen flex flex-col">
    <DemoBanner />
    {!hideChrome && <Header />}
    <main class="flex-1">
      <slot />
    </main>
    {!hideChrome && <Footer />}
    {!hideChrome && <OrderTrackerBar client:load />}
  </body>
</html>
