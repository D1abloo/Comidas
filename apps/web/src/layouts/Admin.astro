---
import '../styles/global.css';
import DemoBanner from '../components/DemoBanner.astro';
import AdminMenu from '../components/islands/AdminMenu.tsx';
import AdminSidebar from '../components/islands/AdminSidebar.tsx';
import AdminAlerts from '../components/islands/AdminAlerts.tsx';
interface Props { title: string; crumb?: string }
const { title, crumb = 'Inicio' } = Astro.props as Props;
const user = Astro.locals.user!;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · BocadO Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bocado-paper text-bocado-ink admin-app font-admin">
    <DemoBanner />
    <AdminAlerts client:load />
    <div class="min-h-[calc(100vh-28px)] flex relative">
      <div class="admin-nav-backdrop fixed inset-0 bg-black/50 z-40 lg:hidden backdrop-blur-sm" aria-hidden="true"></div>

      <aside class="admin-sidebar flex flex-col fixed lg:sticky top-0 left-0 z-50 h-full min-h-[calc(100vh-28px)] -translate-x-full lg:translate-x-0 transition-transform duration-300">
        <AdminSidebar client:load currentPath={path} userName={user.full_name} userEmail={user.email} />
      </aside>

      <div class="flex-1 min-w-0 flex flex-col lg:ml-0 w-full">
        <header class="admin-topbar">
          <div class="flex items-center gap-3 min-w-0">
            <AdminMenu client:load />
            <div class="min-w-0">
              <div class="admin-crumb truncate">{crumb}</div>
              <h1 class="admin-page-title truncate">{title}</h1>
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <slot name="actions" />
            <a href="/" class="admin-store-link hidden sm:inline-flex">Ver tienda ↗</a>
          </div>
        </header>
        <main class="flex-1 admin-content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  .admin-nav-backdrop {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  body.admin-nav-open .admin-nav-backdrop {
    opacity: 1;
    pointer-events: auto;
  }
  body.admin-nav-open .admin-sidebar {
    transform: translateX(0);
  }
  @media (min-width: 1024px) {
    .admin-nav-backdrop {
      display: none;
    }
  }
</style>
