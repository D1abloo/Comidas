---
import '../styles/global.css';
import DemoBanner from '../components/DemoBanner.astro';
import AdminMenu from '../components/islands/AdminMenu.tsx';
interface Props { title: string; crumb?: string }
const { title, crumb = 'Inicio' } = Astro.props as Props;
const user = Astro.locals.user!;
const path = Astro.url.pathname;
const nav = [
  { href: '/admin', label: 'Dashboard', match: '/admin', exact: true,
    icon: 'M3 12 12 3l9 9 M5 10v10h14V10' },
  { href: '/admin/pedidos', label: 'Pedidos', match: '/admin/pedidos',
    icon: 'M4 7h16 M4 12h16 M4 17h10' },
  { href: '/admin/secciones', label: 'Secciones', match: '/admin/secciones',
    icon: 'M4 6h16 M4 12h16 M4 18h10' },
  { href: '/admin/platos', label: 'Platos', match: '/admin/platos',
    icon: 'M3 12h18 M5 8l1.5 -3h11L19 8 M5 8v10h14V8' },
  { href: '/admin/pagos', label: 'Pagos', match: '/admin/pagos',
    icon: 'M3 6h18v13H3z M3 10h18' },
  { href: '/admin/facturas', label: 'Facturas', match: '/admin/facturas',
    icon: 'M6 3h9l4 4v14H6z M9 12h6 M9 16h6' },
  { href: '/admin/avisos', label: 'Avisos', match: '/admin/avisos',
    icon: 'M6 8a6 6 0 1 1 12 0v5l2 3H4l2-3z' },
  { href: '/admin/usuarios', label: 'Usuarios', match: '/admin/usuarios',
    icon: 'M6 21a6 6 0 0 1 12 0 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z' },
  { href: '/admin/ajustes', label: 'Ajustes', match: '/admin/ajustes',
    icon: 'M12 9.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5z M19 12l2 1 -1 3 -2 -1 -1 2 -3 -1 -1 2h-2l-1 -2 -3 1 -1 -2 -2 1 -1 -3 2 -1 -2 -1 1 -3 2 1 1 -2 3 1 1 -2h2l1 2 3 -1 1 2 2 -1 1 3z' },
];
function active(item: { match: string; exact?: boolean }) {
  return item.exact ? path === item.match : path === item.match || path.startsWith(item.match + '/');
}
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · BocadO Admin</title>
    <link rel="preconnect" href="https://rsms.me" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body class="bg-bocado-paper text-bocado-ink admin-app">
    <DemoBanner />
    <div class="min-h-[calc(100vh-28px)] flex relative">
      <div class="admin-nav-backdrop fixed inset-0 bg-black/40 z-40 lg:hidden" aria-hidden="true"></div>

      <aside class="admin-sidebar w-[260px] bg-bocado-ink text-white flex flex-col fixed lg:sticky top-0 left-0 z-50 h-full min-h-[calc(100vh-28px)] -translate-x-full lg:translate-x-0 transition-transform duration-300">
        <a href="/admin" class="h-[72px] flex items-center gap-2.5 px-6 border-b border-white/5 shrink-0">
          <svg width="28" height="28" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <circle cx="20" cy="20" r="18" stroke="#fff" stroke-width="1.2" opacity="0.25" />
            <path d="M10 14c0-3.3 2.5-6 10-6s10 2.7 10 6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" fill="none" />
            <rect x="11" y="19" width="18" height="4.5" rx="2.2" fill="#D6FF3D" />
            <path d="M10 26c0 2.8 2.5 5 10 5s10-2.2 10-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" fill="none" />
          </svg>
          <div>
            <div class="text-[15px] font-semibold tracking-tight leading-none">Bocad<span style="color:#D6FF3D">O</span></div>
            <div class="text-[10px] uppercase tracking-[0.18em] text-white/50 mt-1">Admin</div>
          </div>
        </a>
        <nav class="flex-1 py-4 text-sm overflow-y-auto">
          {nav.map((item) => (
            <a href={item.href}
               class:list={[
                 'flex items-center gap-3 px-6 py-2.5 border-l-2 border-transparent text-white/70 hover:text-white hover:bg-white/5 transition-colors',
                 active(item) && '!text-white !border-bocado-lime bg-white/5',
               ]}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                {item.icon.split(' M ').map((p, i) => <path d={i === 0 ? p : 'M ' + p} />)}
              </svg>
              {item.label}
            </a>
          ))}
        </nav>
        <div class="border-t border-white/5 p-4 text-xs flex items-center justify-between shrink-0">
          <div class="min-w-0">
            <div class="text-white/90 truncate">{user.full_name}</div>
            <div class="text-white/40 text-[10px] truncate">{user.email}</div>
          </div>
          <form action="/api/auth/logout" method="POST">
            <button class="text-white/60 hover:text-white shrink-0" aria-label="Cerrar sesión">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M15 17l5-5-5-5 M20 12H9 M9 21H4V3h5"/></svg>
            </button>
          </form>
        </div>
      </aside>

      <div class="flex-1 min-w-0 flex flex-col lg:ml-0 w-full">
        <header class="h-[64px] sm:h-[72px] border-b border-bocado-line bg-white/80 backdrop-blur flex items-center justify-between gap-3 px-4 sm:px-6 lg:px-8 sticky top-0 z-30">
          <div class="flex items-center gap-3 min-w-0">
            <AdminMenu client:load />
            <div class="min-w-0">
              <div class="text-[10px] sm:text-[11px] uppercase tracking-[0.14em] text-bocado-mute truncate">{crumb}</div>
              <h1 class="text-lg sm:text-xl font-semibold tracking-tight truncate">{title}</h1>
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <slot name="actions" />
            <a href="/" class="btn-ghost text-xs sm:text-sm hidden sm:inline-flex">Ver tienda ↗</a>
          </div>
        </header>
        <main class="flex-1 admin-content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style is:global>
  .admin-nav-backdrop {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  body.admin-nav-open .admin-nav-backdrop {
    opacity: 1;
    pointer-events: auto;
  }
  body.admin-nav-open .admin-sidebar {
    transform: translateX(0);
  }
  @media (min-width: 1024px) {
    .admin-nav-backdrop {
      display: none;
    }
  }
</style>
