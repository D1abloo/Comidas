{
  "name": "@bocado/courier-app",
  "version": "0.1.0",
  "private": true,
  "description": "App Android BocadO Repartidor (Capacitor)",
  "scripts": {
    "config:local": "node scripts/write-config.mjs local",
    "config:prod": "node scripts/write-config.mjs prod",
    "sync": "npx cap sync android",
    "open:android": "npx cap open android",
    "build:apk": "cd android && ./gradlew assembleDebug",
    "build:apk:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "typescript": "^5.5.4"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  }
}
