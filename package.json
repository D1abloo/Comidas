{
  "name": "bocado-delivery",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "npm run dev -w @bocado/web",
    "build": "npm run build -w @bocado/web",
    "start": "npm run start -w @bocado/web",
    "preview": "npm run preview -w @bocado/web",
    "courier:config:prod": "npm run config:prod -w @bocado/courier-app",
    "courier:sync": "npm run sync -w @bocado/courier-app",
    "courier:android": "npm run open:android -w @bocado/courier-app",
    "courier:apk": "npm run build:apk -w @bocado/courier-app",
    "admin:config:prod": "npm run config:prod -w @bocado/admin-app",
    "admin:config:local": "npm run config:local -w @bocado/admin-app",
    "admin:sync": "npm run sync -w @bocado/admin-app",
    "admin:android": "npm run open:android -w @bocado/admin-app",
    "admin:apk": "npm run build:apk -w @bocado/admin-app",
    "mobile:config:prod": "npm run config:prod -w @bocado/mobile-app",
    "mobile:config:local": "npm run config:local -w @bocado/mobile-app",
    "mobile:icons": "npm run icons -w @bocado/mobile-app",
    "mobile:sync": "npm run sync -w @bocado/mobile-app",
    "mobile:android": "npm run open:android -w @bocado/mobile-app",
    "mobile:apk": "npm run build:apk -w @bocado/mobile-app",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f web",
    "deploy:vps": "bash scripts/deploy-vps.sh",
    "smoke:orders": "bash scripts/smoke-orders.sh",
    "apps:config:prod": "npm run mobile:config:prod && npm run courier:config:prod && npm run admin:config:prod"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2"
}
